# Netlify 环境变量设置指南
# -----------------------------------------------------------------------------

# 1. Gemini API Key (用于 AI 分析和面试)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# 2. DeepSeek API Key (用于深度简历分析)
# -----------------------------------------------------------------------------
VITE_DEEPSEEK_API_KEY=

# 3. Supabase 配置 (用于记录用户使用数据)
# -----------------------------------------------------------------------------
# 在 Supabase 项目设置 -> API 中找到以下值
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
